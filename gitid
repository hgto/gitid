#!/usr/bin/env sh
set -eu

GITID_DIR="${GITID_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/git}"

die() { printf 'gitid: %s\n' "$1" >&2; exit "${2:-1}"; }
in_repo() { git rev-parse --is-inside-work-tree >/dev/null 2>&1; }

list_names() {
  for p in "$GITID_DIR"/*.gitconfig; do
    [ -f "$p" ] || continue
    b=${p##*/}; printf '%s\n' "${b%.gitconfig}"
  done
}

# escape ERE metacharacters; uses `#` as the sed delimiter so `/` in paths needs no escaping.
# `]` is first in the bracket so it is literal; the set covers the chars that can appear in a path.
ere_escape() { printf '%s' "$1" | sed 's#[][(){}.^$*+?|\\]#\\&#g'; }
identity_file() { printf '%s/%s.gitconfig' "$GITID_DIR" "$1"; }

strip_local_identity() {
  for key in user.name user.email user.signingkey github.user; do
    git config --local --unset-all "$key" 2>/dev/null || :
  done
}

cmd_apply() {
  name="$1"
  f="$(identity_file "$name")"
  [ -f "$f" ] || die "no identity file: $f"
  in_repo || die "not in a git repo"
  strip_local_identity
  pat="^$(ere_escape "$GITID_DIR")/.*\.gitconfig\$"
  git config --local --unset-all include.path "$pat" 2>/dev/null || :
  git config --local --add include.path "$f"
  printf 'gitid: %s applied\n' "$name"
}

active_identity() {
  git config --local --get-all include.path 2>/dev/null | while IFS= read -r v; do
    case "$v" in
      "$GITID_DIR"/*.gitconfig) b=${v##*/}; printf '%s' "${b%.gitconfig}"; return 0 ;;
    esac
  done
}

cmd_show() {
  in_repo || die "not in a git repo"
  act="$(active_identity)"; [ -n "$act" ] || act="(none / inherited)"
  printf 'name:   %s\n' "$(git config user.name 2>/dev/null || printf '(unset)')"
  printf 'email:  %s\n' "$(git config user.email 2>/dev/null || printf '(unset)')"
  printf 'active: %s\n' "$act"
  if git config --local --get user.email >/dev/null 2>&1 \
     || git config --local --get user.name >/dev/null 2>&1; then
    printf 'gitid: warning: inline local identity present; it shadows includes\n' >&2
  fi
}

repo_urls() {
  in_repo || return 0
  git config --get-regexp '^remote\..*\.url$' 2>/dev/null | while read -r _ u; do printf '%s\n' "$u"; done
}

rule_glob() { g=${1#includeif.}; g=${g%.path}; printf '%s' "${g##*url:}"; }

cmd_rules() {
  urls="$(repo_urls)"
  git config --get-regexp '^includeif\..*\.path$' 2>/dev/null | while IFS= read -r line; do
    key=${line%% *}; val=${line#* }
    glob="$(rule_glob "$key")"
    nm=${val##*/}; nm=${nm%.gitconfig}
    mark="  "
    for u in $urls; do
      # shellcheck disable=SC2254
      case "$u" in $glob) mark="▸ "; break ;; esac
    done
    printf '%s%s -> %s\n' "$mark" "$glob" "$nm"
  done
}

# shellcheck disable=SC2088
expand_tilde() { case "$1" in "~/"*) printf '%s/%s' "$HOME" "${1#~/}" ;; *) printf '%s' "$1" ;; esac; }

expected_identity_file() {
  urls="$(repo_urls)"
  [ -n "$urls" ] || return 0
  git config --get-regexp '^includeif\..*\.path$' 2>/dev/null | while IFS= read -r line; do
    key=${line%% *}; val=${line#* }
    glob="$(rule_glob "$key")"
    for u in $urls; do
      # shellcheck disable=SC2254
      case "$u" in $glob) printf '%s' "$val"; return 0 ;; esac
    done
  done
}

cmd_check() {
  in_repo || die "not in a git repo"
  eff="$(git config user.email 2>/dev/null || true)"
  exp_file="$(expected_identity_file)"
  if [ -z "$exp_file" ]; then
    [ -n "$eff" ] && { printf 'gitid: ok (no rule matches; identity=%s)\n' "$eff"; return 0; }
    die "no identity set and no matching rule"
  fi
  exp_email="$(git config -f "$(expand_tilde "$exp_file")" user.email 2>/dev/null || true)"
  if [ "$eff" = "$exp_email" ] && [ -n "$eff" ]; then
    printf 'gitid: ok (%s)\n' "$eff"; return 0
  fi
  nm=${exp_file##*/}; nm=${nm%.gitconfig}
  printf 'gitid: identity mismatch: effective=%s expected=%s\n  fix: gitid %s\n' "${eff:-(unset)}" "$exp_email" "$nm" >&2
  return 1
}

cmd_migrate() {
  apply=0; dir="."
  for a in "$@"; do
    case "$a" in --apply) apply=1 ;; *) dir="$a" ;; esac
  done
  find "$dir" -type d -name .git 2>/dev/null | while IFS= read -r g; do
    repo=${g%/.git}
    had=""
    for key in user.name user.email user.signingkey github.user; do
      v="$(git -C "$repo" config --local --get "$key" 2>/dev/null || true)"
      [ -n "$v" ] && had="$had $key"
    done
    if [ -z "$had" ]; then printf 'clean       %s\n' "$repo"; continue; fi
    if [ "$apply" -eq 1 ]; then
      for key in user.name user.email user.signingkey github.user; do
        git -C "$repo" config --local --unset-all "$key" 2>/dev/null || :
      done
      printf 'cleaned     %s (%s )\n' "$repo" "$had"
    else
      printf 'would-clean %s (%s )\n' "$repo" "$had"
    fi
  done
}

global_config_file() {
  if [ -n "${GIT_CONFIG_GLOBAL:-}" ]; then printf '%s' "$GIT_CONFIG_GLOBAL"
  elif [ -f "${XDG_CONFIG_HOME:-$HOME/.config}/git/config" ]; then printf '%s' "${XDG_CONFIG_HOME:-$HOME/.config}/git/config"
  else printf '%s' "$HOME/.gitconfig"; fi
}

cmd_migrate_global() {
  apply=0; for a in "$@"; do [ "$a" = "--apply" ] && apply=1; done
  files="$(global_config_file)"
  # add files referenced by UNCONDITIONAL include.path (never includeif.*.path)
  inc="$(git config --global --get-all include.path 2>/dev/null || true)"
  for p in $inc; do files="$files
$(expand_tilde "$p")"; done
  printf '%s\n' "$files" | while IFS= read -r fpath; do
    [ -n "$fpath" ] && [ -f "$fpath" ] || continue
    had=""
    for key in user.name user.email user.signingkey github.user; do
      v="$(git config -f "$fpath" --get "$key" 2>/dev/null || true)"
      [ -n "$v" ] && had="$had $key"
    done
    if [ -z "$had" ]; then printf 'clean       %s\n' "$fpath"; continue; fi
    if [ "$apply" -eq 1 ]; then
      for key in user.name user.email user.signingkey github.user; do
        git config -f "$fpath" --unset-all "$key" 2>/dev/null || :
      done
      printf 'cleaned     %s (%s )\n' "$fpath" "$had"
    else
      printf 'would-clean %s (%s )\n' "$fpath" "$had"
    fi
  done
}

cmd_help() {
  printf 'usage: gitid <name>|show|rules|check|migrate [dir]|migrate-global|completion <bash|zsh>\n'
  printf '  GITID_DIR=%s\n' "$GITID_DIR"
  printf 'identities:\n'
  list_names | sed 's/^/  /'
}

main() {
  cmd="${1:-help}"
  case "$cmd" in
    help|-h|--help|"") cmd_help ;;
    show) shift; cmd_show "$@" ;;
    rules) shift; cmd_rules "$@" ;;
    check) shift; cmd_check "$@" ;;
    migrate) shift; cmd_migrate "$@" ;;
    migrate-global) shift; cmd_migrate_global "$@" ;;
    *) cmd_apply "$cmd" ;;
  esac
}

main "$@"
